{
  "entities": {
    "GameRoom": {
      "title": "Game Room",
      "description": "Represents a multiplayer game room.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique ID of the room." },
        "name": { "type": "string", "description": "The name of the room, often created from the host's nickname." },
        "players": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "userId": { "type": "string" },
              "nickname": { "type": "string" },
              "playerId": { "type": "string", "enum": ["Red", "Green", "Blue", "Yellow"]}
            },
            "required": ["userId", "nickname", "playerId"]
          }
        },
        "gameState": {
          "type": "string",
          "description": "JSON string of the complete GameState object."
        },
        "status": {
          "type": "string",
          "enum": ["waiting", "in-progress", "finished"]
        },
        "createdAt": {
          "type": "object"
        }
      },
      "required": ["id", "name", "players", "gameState", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": []
  },
  "firestore": {
    "/rooms/{roomId}": {
      "schema": { "$ref": "#/entities/GameRoom" },
      "description": "Collection of all game rooms."
    }
  }
}
